APP_ENV=production
APP_PASSWORD=replace-with-a-strong-password
TOKEN_SECRET=replace-with-at-least-32-random-characters
CORS_ALLOWED_ORIGINS=https://your-frontend.onrender.com
ACCESS_TOKEN_TTL_MINUTES=60
LOGIN_MAX_FAILURES=5
LOGIN_FAILURE_WINDOW_SECONDS=60
SHIFT_RANGE=4
JOB_TTL_MINUTES=60
MAX_VIDEO_DURATION_SECONDS=900
MAX_SOURCE_MB=150
MAX_QUEUE_SIZE=5
MAX_CONCURRENT_JOBS=1
WORK_ROOT=/tmp/yks
LOG_LEVEL=INFO
YTDLP_COOKIES_FILE=
ENABLE_MELODY_ANALYSIS=false
MELODY_TIMEOUT_SECONDS=300
MELODY_MIN_NOTE_DURATION_SEC=0.12
MELODY_MAX_GAP_MERGE_SEC=0.08
MELODY_MIN_CONFIDENCE=0.45
MELODY_FMIN=C2
MELODY_FMAX=C6
MELODY_MAX_NOTES=2000
STEM_SEPARATION_ENABLED=false
STEM_SEPARATION_BACKEND=auto
STEM_SEPARATION_DEVICE=auto
DEMUCS_PYTHON=/home/startech/venvs/yt2mp3-gpu/bin/python
DEMUCS_MODEL=htdemucs
DEMUCS_TWO_STEMS=vocals
DEMUCS_TIMEOUT_SECONDS=900
DEMUCS_CLEAN_ENV=true
RMVPE_PYTHON=/home/startech/venvs/yt2mp3-gpu/bin/python
RMVPE_TIMEOUT_SECONDS=300
RMVPE_VOICED_CONFIDENCE_THRESHOLD=0.03
ALLOW_CPU_HEAVY_MODE=false
STEM_CACHE_ENABLED=true
MELODY_SOURCE_PRIORITY=vocals
